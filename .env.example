APP_ENV=development
APP_NAME=Resume Navigator
LOG_LEVEL=INFO

DATABASE_URL=sqlite:///data/runtime/resume_navigator.db
DATA_DIR=data/runtime
UPLOAD_DIR=data/uploads
EXPORT_DIR=data/exports

GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_ACCESS_MODE=byok
ENABLE_OPTIONAL_LLM=false

ENABLE_EXTERNAL_ENRICHMENT=false
ENABLE_PUBLIC_RESEARCH=false
PUBLIC_RESEARCH_MAX_RESULTS=5
ENABLE_PRIVATE_RESEARCH_CONNECTORS=false
PRIVATE_RESEARCH_CONNECTORS=boss_private
